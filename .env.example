# ---------------------------------------------------------------------------
# LaunchLens Research Studio — environment template
# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in the values you need.
#   cp .env.example .env.local
#
# Without any provider keys, the app runs on a deterministic MOCK provider so
# the demo always works. To run real research with a live LLM, set ONE of the
# API keys below and (optionally) a base URL / model override.
# ---------------------------------------------------------------------------

# === Provider selection ====================================================
# Optional. Forces a specific provider regardless of which keys are set.
#   - "mock"      -> always use the deterministic mock (demo data)
#   - "openai"    -> use the OpenAI adapter (requires an OpenAI key)
#   - "anthropic" -> use the Anthropic adapter (requires an Anthropic key)
# When unset, the registry auto-selects: Anthropic key > OpenAI key > mock.
# LAUNCHLENS_PROVIDER=anthropic

# === OpenAI ================================================================
# Either variable works; LAUNCHLENS_OPENAI_KEY takes precedence if both are set.
# OPENAI_API_KEY=sk-...
# LAUNCHLENS_OPENAI_KEY=sk-...
# Optional: a custom base URL for OpenAI-compatible gateways (Azure, local, etc.).
# Production URLs must use HTTPS; HTTP is accepted only for loopback development.
# OPENAI_BASE_URL=https://api.openai.com/v1
# Optional: model name. Defaults to gpt-4o-mini.
# OPENAI_MODEL=gpt-4o-mini

# === MiniMax (OpenAI-compatible) ============================================
# MiniMax exposes an OpenAI-compatible chat completions endpoint, so you
# reuse the OpenAI adapter with a different base URL and model. MiniMax-M3 is
# a reasoning model — its <think>…</think> blocks are stripped automatically
# by the json-extract module before parsing. Verified end-to-end (round 209).
# LAUNCHLENS_PROVIDER=openai
# OPENAI_API_KEY=sk-cp-...
# OPENAI_BASE_URL=https://api.minimaxi.com/v1
# OPENAI_MODEL=MiniMax-M3

# === Anthropic =============================================================
# ANTHROPIC_API_KEY=sk-ant-...
# Optional: a custom base URL for Anthropic-compatible gateways. Production
# URLs must use HTTPS; URL credentials, queries, and fragments are rejected.
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# Optional: model name. Defaults to claude-3-5-sonnet-latest.
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ---------------------------------------------------------------------------
# NOTE: Only server-side code reads these keys. They are never exposed to the
# browser. Restart `npm run dev` after editing `.env.local` for changes to take
# effect. See docs/PROVIDERS.md for the full configuration guide.
# ---------------------------------------------------------------------------

# === Scheduled research cron trigger =========================================
# R212: the scheduler module ships an in-process `setInterval` poller that
# only fires while the Node.js runtime stays resident. On serverless
# platforms (Vercel, Cloudflare, AWS Lambda) the function freezes between
# invocations and scheduled runs never execute.
#
# To run schedules reliably on serverless, point an external cron service
# (Vercel Cron, GitHub Actions, k8s CronJob, etc.) at:
#   POST /api/cron/scheduler
# with the `x-cron-secret` header (or `Authorization: Bearer <secret>`)
# set to the value below. The repository's GitHub Actions recovery workflow
# runs every five minutes; Vercel Cron is a daily platform fallback for Hobby
# compatibility. The endpoint refuses all calls when the secret is unset.
# CRON_SECRET=replace-with-a-long-random-string
# Legacy alias for non-Vercel schedulers: LAUNCHLENS_CRON_SECRET

# === Web retrieval / RAG grounding (R215) ====================================
# Set TAVILY_API_KEY to enable Tavily-backed retrieval: each agent receives
# trusted source context and the engine drops citation URLs outside the
# retrieval allowlist. Deep Research requires Tavily and fails closed without
# it; Standard may continue with clearly labelled mock/degraded provenance.
#
# Get a key at https://tavily.com (free tier OK). Without a key, Standard may
# use mock/degraded retrieval; Deep remains unavailable.
#
# Optional overrides:
#   LAUNCHLENS_SEARCH_PROVIDER=tavily   # explicit; default auto-selects when key is set
#   LAUNCHLENS_SEARCH_PROVIDER=mock     # force off even when a key is present
#   TAVILY_BASE_URL=https://api.tavily.com   # HTTPS self-hosted / proxy endpoint
# TAVILY_API_KEY=tvly-...

# === Persistence / storage ===================================================
# On a long-running host, set LAUNCHLENS_STORAGE_DIR to a writable directory
# for the local History store. Serverless filesystems are per-instance, so
# production session recovery uses Upstash Redis / Vercel KV instead. Configure
# either UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN or
# KV_REST_API_URL + KV_REST_API_TOKEN.
# LAUNCHLENS_STORAGE_DIR=/tmp

# === Deep Research production gate ===========================================
# Deep uses a Redis-authoritative eleven-unit work graph. Leave the opt-in at 0
# until every requirement returned by GET /api/research/capabilities is ready.
# The worker secret and cron secret must be distinct and at least 24 characters.
#
# IMPORTANT: `.github/workflows/deep-recovery.yml` is the five-minute recovery
# trigger. Add the same cron value as the repository secret
# `LAUNCHLENS_CRON_SECRET`, then verify a real production invocation. The daily
# `vercel.json` cron is only a secondary fallback on Vercel Hobby.
# LAUNCHLENS_DEEP_ENABLED=0
# LAUNCHLENS_DEEP_WORKER_SECRET=replace-with-a-distinct-long-random-string
# LAUNCHLENS_DEEP_WORKER_BASE_URL=https://research.example.com
# LAUNCHLENS_DEEP_RECOVERY_MODE=cron
# LAUNCHLENS_DEEP_RECOVERY_MAX_DELAY_SECONDS=300
#
# Durable cost/admission guard. A single Redis transaction enforces both UTC
# daily starts and expiring active reservations across all serverless instances.
# Invalid values are clamped to safe bounds; Redis failures reject Deep starts.
# The optional hash secret protects client identifiers stored in Redis. When
# omitted, the already-required Deep worker secret is used.
# LAUNCHLENS_DEEP_PER_CLIENT_DAILY_LIMIT=2
# LAUNCHLENS_DEEP_GLOBAL_DAILY_LIMIT=20
# LAUNCHLENS_DEEP_PER_CLIENT_ACTIVE_LIMIT=1
# LAUNCHLENS_DEEP_GLOBAL_ACTIVE_LIMIT=3
# LAUNCHLENS_DEEP_RESERVATION_SECONDS=3600
# LAUNCHLENS_DEEP_ADMISSION_HASH_SECRET=replace-with-another-long-random-string
#
# A strict structured reviewer is required. It can reuse the main provider key,
# or use a dedicated key/model for independent review.
# LAUNCHLENS_REVIEW_PROVIDER=openai
# LAUNCHLENS_REVIEW_MODEL=gpt-5-mini
# LAUNCHLENS_REVIEW_OPENAI_KEY=sk-...
# LAUNCHLENS_REVIEW_ANTHROPIC_KEY=sk-ant-...
# LAUNCHLENS_REVIEW_BASE_URL=https://api.openai.com/v1

# === Session / engine tuning =================================================
# R216 — per-agent wall-clock timeout (ms). Default 180000 = 180s. A real
# LLM call that hangs (flaky upstream, slow gateway) is aborted at this
# budget; the agent falls back to mock and the session keeps moving.
# LAUNCHLENS_AGENT_TIMEOUT_MS=180000

# Maximum concurrent real-provider streams. Default 3. Lower this if an
# upstream gateway is rate-limited; mock mode bypasses the limiter.
# LAUNCHLENS_PROVIDER_CONCURRENCY=3

# R217 — how long (ms) terminal sessions stay in the in-memory map before
# eviction. Default 1800000 = 30 minutes. On serverless this is bounded by
# function lifetime instead; the value here still controls the local dev /
# long-running host behavior.
# LAUNCHLENS_SESSION_RETENTION_MS=1800000

# How long completed/cancelled/error session snapshots remain recoverable from
# Redis (seconds). Default 2592000 = 30 days. This keeps report and LaunchLens
# brief URLs usable after the 30-minute in-memory live-session window.
# LAUNCHLENS_TERMINAL_SESSION_TTL_SECONDS=2592000

# R218 — admin smoke probe wall-clock budget (ms). The /api/research/smoke
# admin-gated endpoint uses this to bound a full 6-agent run for health checks.
# LAUNCHLENS_SMOKE_TIMEOUT_MS=600000

# === Rate limiting ===========================================================
# Token-bucket per-IP rate limit for mutating endpoints (research POST,
# share, batch, etc.). Default capacity 10 tokens, refills 1 every 1000ms.
# Tighten for production behind a public domain; loosen for local stress tests.
# LAUNCHLENS_RATE_LIMIT_CAPACITY=10
# LAUNCHLENS_RATE_LIMIT_REFILL_MS=1000

# === Auth / CORS / CSRF / Trusted IPs ========================================
# LAUNCHLENS_CORS_ORIGINS — comma-separated allow-list of origins permitted
# to call the API. Empty = same-origin only.
# LAUNCHLENS_CORS_ORIGINS=https://research.launchlens.ai,https://launchlens.ai

# LAUNCHLENS_CSRF_STRICT — when "true", CSRF protection rejects any mutating
# request without a valid x-csrf-token header. Leave "true" in production.
# LAUNCHLENS_CSRF_STRICT=true

# LAUNCHLENS_TRUSTED_IPS — comma-separated CIDR/IP list exempt from
# CSRF + same-origin checks. Use for Vercel edge IPs / health-check probers.
# LAUNCHLENS_TRUSTED_IPS=

# === Bypass / admin tokens ===================================================
# LAUNCHLENS_BYPASS_TOKENS — comma-separated token:label pairs granting
# admin-gated endpoint access without full Auth. Each token is opaque;
# use a long random string. Owners rotate by editing this var + redeploying.
# LAUNCHLENS_BYPASS_TOKENS=

# LAUNCHLENS_ADMIN_TOKENS — comma-separated token:label pairs granting
# elevated admin endpoints (token revoke, alerts). Take precedence over
# LAUNCHLENS_BYPASS_TOKENS. Generate with: openssl rand -hex 32
# LAUNCHLENS_ADMIN_TOKENS=

# LAUNCHLENS_TOKEN_DEFAULT_TTL_MS — default lifetime (ms) of a freshly issued
# bypass token. Default 86400000 = 24h. R227 enforces lazy expiry regardless.
# LAUNCHLENS_TOKEN_DEFAULT_TTL_MS=86400000

# === Health probe key ========================================================
# LAUNCHLENS_PROBE_KEY — shared secret for /api/health. When set, the
# endpoint requires x-probe-key=<value>; empty disables auth (dev only).
# LAUNCHLENS_PROBE_KEY=

# === Auth alerts / webhooks (optional) =======================================
# When any *_THRESHOLD is exceeded within LAUNCHLENS_ALERT_WINDOW_SECONDS,
# a single POST is fired to LAUNCHLENS_ALERT_WEBHOOK_URL with HMAC
# signature header x-alert-signature. All eight vars are optional; leave
# empty to disable alerting entirely.
# LAUNCHLENS_ALERT_WINDOW_SECONDS=300
# LAUNCHLENS_ALERT_AUTH_FAILED_THRESHOLD=20
# LAUNCHLENS_ALERT_CSRF_FAILED_THRESHOLD=20
# LAUNCHLENS_ALERT_RATE_LIMITED_THRESHOLD=50
# LAUNCHLENS_ALERT_WEBHOOK_URL=
# LAUNCHLENS_ALERT_WEBHOOK_SECRET=
# LAUNCHLENS_ALERT_WEBHOOK_MAX_RETRIES=3
# LAUNCHLENS_ALERT_WEBHOOK_RETRY_DELAY=1000

# === Scheduler poll cadence (reserved) =======================================
# LAUNCHLENS_POLL_INTERVAL_MS — referenced by .env.example §"Scheduled
# research cron trigger" but not currently consumed by code. The cron
# endpoint (POST /api/cron/scheduler) is the authoritative trigger on
# serverless — see the cron section above. Reserved for future in-process
# fallback on long-running hosts.
# LAUNCHLENS_POLL_INTERVAL_MS=60000

# === Cross-project integration (R231) ========================================
# R231: the "Send to LaunchLens AI" button in the Export panel opens
# launchlens-ai in a new tab with the 5-field brief embedded in the URL
# hash (#brief=<base64url>). launchlens-ai auto-detects that hash on
# landing and pre-fills the brief builder. Both vars are NEXT_PUBLIC_*
# because the click handler runs in the browser; they are NOT secrets.
#
# NEXT_PUBLIC_LAUNCHLENS_AI_URL — destination domain for the brief
# handoff. Default points at the public production deployment. Set to a
# staging URL when testing the integration before pushing.
# NEXT_PUBLIC_LAUNCHLENS_AI_URL=https://launchlens-ai-two.vercel.app
#
# NEXT_PUBLIC_RESEARCH_STUDIO_URL — origin the envelope's reportUrl field
# points at, so launchlens-ai's workspace can back-link to the live
# research report. Default matches the Vercel preview domain. Override
# when running behind a custom domain (e.g. research.launchlens.ai).
# NEXT_PUBLIC_RESEARCH_STUDIO_URL=https://launchlens-research-studio.vercel.app
