# ---------------------------------------------------------------------------
# LaunchLens Research Studio — environment template
# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in the values you need.
#   cp .env.example .env.local
#
# Without any provider keys, the app runs on a deterministic MOCK provider so
# the demo always works. To run real research with a live LLM, set ONE of the
# API keys below and (optionally) a base URL / model override.
# ---------------------------------------------------------------------------

# === Provider selection ====================================================
# Optional. Forces a specific provider regardless of which keys are set.
#   - "mock"      -> always use the deterministic mock (demo data)
#   - "openai"    -> use the OpenAI adapter (requires an OpenAI key)
#   - "anthropic" -> use the Anthropic adapter (requires an Anthropic key)
# When unset, the registry auto-selects: Anthropic key > OpenAI key > mock.
# LAUNCHLENS_PROVIDER=anthropic

# === OpenAI ================================================================
# Either variable works; LAUNCHLENS_OPENAI_KEY takes precedence if both are set.
# OPENAI_API_KEY=sk-...
# LAUNCHLENS_OPENAI_KEY=sk-...
# Optional: a custom base URL for OpenAI-compatible gateways (Azure, local, etc.)
# OPENAI_BASE_URL=https://api.openai.com/v1
# Optional: model name. Defaults to gpt-4o-mini.
# OPENAI_MODEL=gpt-4o-mini

# === MiniMax (OpenAI-compatible) ============================================
# MiniMax exposes an OpenAI-compatible chat completions endpoint, so you
# reuse the OpenAI adapter with a different base URL and model. MiniMax-M3 is
# a reasoning model — its <think>…</think> blocks are stripped automatically
# by the json-extract module before parsing. Verified end-to-end (round 209).
# LAUNCHLENS_PROVIDER=openai
# OPENAI_API_KEY=sk-cp-...
# OPENAI_BASE_URL=https://api.minimaxi.com/v1
# OPENAI_MODEL=MiniMax-M3

# === Anthropic =============================================================
# ANTHROPIC_API_KEY=sk-ant-...
# Optional: a custom base URL for Anthropic-compatible gateways.
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# Optional: model name. Defaults to claude-3-5-sonnet-latest.
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ---------------------------------------------------------------------------
# NOTE: Only server-side code reads these keys. They are never exposed to the
# browser. Restart `npm run dev` after editing `.env.local` for changes to take
# effect. See docs/PROVIDERS.md for the full configuration guide.
# ---------------------------------------------------------------------------
